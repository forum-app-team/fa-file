# File Service environment example
NODE_ENV=development
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Authentication (mock)
# For demo we accept tokens like: "Bearer demo-<userId>"
JWT_PUBLIC_KEY=MOCK

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET
S3_BUCKET=your-bucket-name
# Optional custom endpoint (e.g., for MinIO/localstack)
S3_ENDPOINT=
# Public base URL for serving files (CDN or S3)
S3_PUBLIC_BASE_URL=https://your-bucket-name.s3.us-east-1.amazonaws.com
# Server-side encryption mode: AES256 or aws:kms
S3_SSE=AES256

# Presign config
PRESIGN_EXPIRES_SECONDS=600

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Testing/dev
MOCK_S3=true

